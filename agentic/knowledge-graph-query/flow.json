            "template": {
              "_type": "CustomComponent",
              "code": {
                "field_type": "code",
                "required": true,
                "show": true,
                "name": "code",
                "display_name": "Code",
                "advanced": false,
                "value": "import json\nfrom pathlib import Path\nfrom langflow.custom import CustomComponent\nfrom langflow.schema import Record\n\nclass GraphLoaderComponent(CustomComponent):\n    display_name = \"Graph Loader\"\n    description = \"Loads knowledge-graph/graph.json and returns it as formatted text\"\n\n    def build_config(self):\n        return {\n            \"graph_path\": {\n                \"display_name\": \"Graph JSON Path\",\n                \"field_type\": \"str\",\n                \"required\": False,\n                \"value\": \"knowledge-graph/graph.json\",\n            }\n        }\n\n    def build(self, graph_path: str = \"knowledge-graph/graph.json\") -> str:\n        path = Path(graph_path)\n        if not path.is_absolute():\n            # Try relative to CWD\n            path = Path.cwd() / graph_path\n        if not path.exists():\n            return f\"ERROR: graph.json not found at {path}\"\n\n        graph = json.loads(path.read_text())\n        lines = []\n        lines.append(f\"# Knowledge Graph ({len(graph['nodes'])} nodes, {len(graph['edges'])} edges)\")\n        lines.append(\"\")\n        lines.append(\"## Nodes\")\n        for n in graph[\"nodes\"]:\n            attrs = \", \".join(f\"{k}={v}\" for k, v in n[\"attrs\"].items() if k != \"name\")\n            name = n[\"attrs\"].get(\"name\", n[\"id\"])\n            lines.append(f\"- [{n['type']}] {n['id']} — {name}\" + (f\" ({attrs})\" if attrs else \"\"))\n        lines.append(\"\")\n        lines.append(\"## Relationships\")\n        for e in graph[\"edges\"]:\n            lines.append(f\"- {e['from']} --[{e['rel']}]--> {e['to']}\")\n        return \"\\n\".join(lines)\n"
              }
            },
            "description": "Loads and formats graph.json as text for LLM context",
            "display_name": "Graph Loader",
            "documentation": "",
            "base_classes": ["Message", "Text"]
          }
