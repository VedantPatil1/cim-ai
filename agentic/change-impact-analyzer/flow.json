      {
        "id": "CustomComponent-impact",
        "type": "genericNode",
        "position": { "x": 500, "y": 430 },
        "data": {
          "id": "CustomComponent-impact",
          "type": "CustomComponent",
          "node": {
            "template": {
              "_type": "CustomComponent",
              "code": {
                "field_type": "code",
                "required": true,
                "show": true,
                "name": "code",
                "display_name": "Code",
                "advanced": false,
                "value": "import json\nfrom pathlib import Path\nfrom langflow.custom import CustomComponent\n\nclass ImpactExtractorComponent(CustomComponent):\n    display_name = \"Impact Extractor\"\n    description = \"Extracts the subgraph relevant to a target node for blast radius analysis\"\n\n    def build_config(self):\n        return {\n            \"graph_path\": {\"display_name\": \"Graph JSON Path\", \"field_type\": \"str\", \"required\": False, \"value\": \"knowledge-graph/graph.json\"},\n            \"target_node\": {\"display_name\": \"Target Node ID\", \"field_type\": \"str\", \"required\": False, \"value\": \"\"},\n        }\n\n    def build(self, graph_path: str = \"knowledge-graph/graph.json\", target_node: str = \"\") -> str:\n        path = Path(graph_path)\n        if not path.is_absolute():\n            path = Path.cwd() / graph_path\n        if not path.exists():\n            return f\"ERROR: graph.json not found at {path}\"\n\n        graph = json.loads(path.read_text())\n        nodes_by_id = {n[\"id\"]: n for n in graph[\"nodes\"]}\n        edges = graph[\"edges\"]\n\n        if not target_node:\n            # Return full graph summary\n            lines = [f\"# Full Graph Context ({len(graph['nodes'])} nodes, {len(graph['edges'])} edges)\"]\n            lines.append(\"\\n## All Nodes\")\n            for n in graph[\"nodes\"]:\n                lines.append(f\"- [{n['type']}] {n['id']}\")\n            lines.append(\"\\n## All Edges\")\n            for e in edges:\n                lines.append(f\"- {e['from']} --[{e['rel']}]--> {e['to']}\")\n            return \"\\n\".join(lines)\n\n        # BFS: find all nodes reachable from target (both directions)\n        visited = set()\n        queue = [target_node]\n        relevant_edges = []\n        while queue:\n            node_id = queue.pop(0)\n            if node_id in visited:\n                continue\n            visited.add(node_id)\n            for e in edges:\n                if e[\"from\"] == node_id and e[\"to\"] not in visited:\n                    relevant_edges.append(e)\n                    queue.append(e[\"to\"])\n                if e[\"to\"] == node_id and e[\"from\"] not in visited:\n                    relevant_edges.append(e)\n                    queue.append(e[\"from\"])\n\n        lines = [f\"# Impact Subgraph for: {target_node}\"]\n        lines.append(f\"Reachable nodes: {len(visited)}\")\n        lines.append(\"\\n## Connected Nodes\")\n        for nid in visited:\n            n = nodes_by_id.get(nid, {\"type\": \"Unknown\", \"attrs\": {}})\n            lines.append(f\"- [{n.get('type', '?')}] {nid}\")\n        lines.append(\"\\n## Relevant Relationships\")\n        seen_edges = set()\n        for e in relevant_edges:\n            key = f\"{e['from']}-{e['rel']}-{e['to']}\"\n            if key not in seen_edges:\n                seen_edges.add(key)\n                lines.append(f\"- {e['from']} --[{e['rel']}]--> {e['to']}\")\n        return \"\\n\".join(lines)\n"
              }
            },
            "description": "Extracts subgraph for blast radius computation",
            "display_name": "Impact Extractor",
            "documentation": "",
            "base_classes": ["Message", "Text"]
          }
        }
      },
