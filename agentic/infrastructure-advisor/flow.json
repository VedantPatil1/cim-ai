          "node": {
            "template": {
              "_type": "CustomComponent",
              "code": {
                "field_type": "code",
                "required": true,
                "show": true,
                "name": "code",
                "display_name": "Code",
                "advanced": false,
                "value": "import json\nfrom pathlib import Path\nfrom langflow.custom import CustomComponent\n\nclass KGContextComponent(CustomComponent):\n    display_name = \"KG Context Builder\"\n    description = \"Loads graph.json and produces a compact system context string\"\n\n    def build_config(self):\n        return {\n            \"graph_path\": {\"display_name\": \"Graph JSON Path\", \"field_type\": \"str\", \"required\": False, \"value\": \"knowledge-graph/graph.json\"}\n        }\n\n    def build(self, graph_path: str = \"knowledge-graph/graph.json\") -> str:\n        path = Path(graph_path)\n        if not path.is_absolute():\n            path = Path.cwd() / graph_path\n        if not path.exists():\n            return \"[Knowledge graph not available]\"\n\n        graph = json.loads(path.read_text())\n\n        # Group nodes by type for compact display\n        by_type: dict = {}\n        for n in graph[\"nodes\"]:\n            by_type.setdefault(n[\"type\"], []).append(n)\n\n        lines = [\"## Infrastructure Knowledge Graph\\n\"]\n        for ntype, nodes in by_type.items():\n            lines.append(f\"### {ntype}s\")\n            for n in nodes:\n                name = n[\"attrs\"].get(\"name\", n[\"id\"])\n                extras = []\n                for k in [\"language\", \"tier\", \"enforcer\", \"trigger\"]:\n                    if k in n[\"attrs\"]:\n                        extras.append(f\"{k}={n['attrs'][k]}\")\n                line = f\"- `{n['id']}` ({name})\"\n                if extras:\n                    line += f\" [{', '.join(extras)}]\"\n                lines.append(line)\n            lines.append(\"\")\n\n        lines.append(\"### Key Relationships\")\n        for e in graph[\"edges\"]:\n            lines.append(f\"- {e['from']} --[{e['rel']}]--> {e['to']}\")\n\n        return \"\\n\".join(lines)\n"
              }
            },
            "description": "Loads and compacts graph.json into system context",
            "display_name": "KG Context Builder",
            "documentation": "",
            "base_classes": ["Message", "Text"]
          }
        }
      },
